{
  "id": "openclaw-f2a",
  "name": "F2A P2A Network Plugin",
  "version": "0.5.0",
  "description": "OpenClaw plugin for F2A P2P Agent network",
  "skills": ["./skills"],
  "configSchema": {
    "type": "object",
    "properties": {
      "webhookPath": {
        "type": "string",
        "default": "/f2a/webhook",
        "description": "Webhook 接收路径 (由 OpenClaw Gateway 处理)"
      },
      "webhookToken": {
        "type": "string",
        "default": "",
        "description": "Webhook 认证 Token"
      },
      "agentTimeout": {
        "type": "number",
        "default": 60000,
        "description": "Agent 响应超时时间（毫秒）"
      },
      "controlPort": {
        "type": "number",
        "default": 9001,
        "description": "F2A Daemon 控制端口"
      },
      "agentName": {
        "type": "string",
        "default": "OpenClaw Agent",
        "description": "Agent 名称"
      },
      "agentCapabilities": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["chat", "task"],
        "description": "Agent 能力列表"
      },
      "runtimeId": {
        "type": "string",
        "default": "local-openclaw",
        "description": "OpenClaw runtime 实例 ID"
      },
      "agents": {
        "type": "array",
        "description": "Agent-first 多 Agent connect 配置。每个条目绑定一个 OpenClaw agents.list[].id 到一个 F2A Agent。",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["openclawAgentId"],
          "properties": {
            "openclawAgentId": {
              "type": "string",
              "description": "OpenClaw agents.list[].id"
            },
            "f2aAgentId": {
              "type": "string",
              "description": "已有 F2A AgentId。省略时创建新的 F2A Agent。"
            },
            "name": {
              "type": "string",
              "description": "F2A Agent 展示名称"
            },
            "capabilities": {
              "type": "array",
              "items": { "type": "string" },
              "description": "该 Agent 的 F2A 能力列表"
            },
            "webhookPath": {
              "type": "string",
              "description": "可选的 Agent 专属 webhook path"
            }
          }
        },
        "default": []
      },
      "autoRegister": {
        "type": "boolean",
        "default": true,
        "description": "启动时自动注册到 Daemon"
      },
      "registerRetryInterval": {
        "type": "number",
        "default": 5000,
        "description": "注册重试间隔（毫秒）"
      },
      "registerMaxRetries": {
        "type": "number",
        "default": 3,
        "description": "最大注册重试次数"
      }
    },
    "additionalProperties": false
  }
}
