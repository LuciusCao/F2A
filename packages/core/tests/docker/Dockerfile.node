# F2A Node Docker Image
# 用于在容器中运行 F2A 节点

FROM node:22-alpine

# 安装 better-sqlite3 所需的构建工具
RUN apk add --no-cache python3 make g++

WORKDIR /app

# 复制整个 monorepo
COPY . .

# 在根目录安装所有 workspace 依赖
RUN npm install

# 构建 packages/core
RUN npm run build -w @f2a/network

# 环境变量
ENV NODE_ENV=production
ENV F2A_CONTROL_PORT=9001

# 健康检查
HEALTHCHECK --interval=5s --timeout=3s --retries=10 \
  CMD wget -q --spider http://localhost:9001/health || exit 1

# 启动命令
CMD ["node", "packages/core/dist/daemon/main.js"]