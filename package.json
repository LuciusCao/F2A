{
  "name": "@f2a/core",
  "version": "1.0.0",
  "description": "Friend-to-Agent P2P networking protocol for OpenClaw Agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "SKILL.md",
    "references/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "agent",
    "p2p",
    "f2a",
    "openclaw",
    "networking",
    "decentralized"
  ],
  "author": "LuciusCao",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "eventemitter3": "^5.0.0",
    "zod": "^3.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}