{
  "id": "openclaw-f2a",
  "extension": "./dist/plugin.js",
  "name": "F2A Webhook Handler",
  "description": "Minimal OpenClaw plugin for F2A - receives webhooks and forwards messages to Agent",
  "version": "0.4.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "webhookPath": {
        "type": "string",
        "description": "Webhook endpoint path",
        "default": "/f2a/webhook"
      },
      "webhookToken": {
        "type": "string",
        "description": "Auth token for webhook requests",
        "sensitive": true
      },
      "controlPort": {
        "type": "number",
        "description": "Port for F2A daemon control API",
        "default": 9001
      },
      "controlToken": {
        "type": "string",
        "description": "Auth token for F2A daemon control API (auto-loaded from ~/.f2a/control-token)",
        "sensitive": true
      },
      "agentTimeout": {
        "type": "number",
        "description": "Timeout for Agent response (milliseconds)",
        "default": 60000
      }
    }
  },
  "uiHints": {
    "webhookPath": { "label": "Webhook Path", "placeholder": "/f2a/webhook" },
    "webhookToken": { "label": "Webhook Token", "sensitive": true },
    "controlPort": { "label": "Control Port" },
    "controlToken": { "label": "Control Token", "sensitive": true },
    "agentTimeout": { "label": "Agent Timeout (ms)" }
  }
}