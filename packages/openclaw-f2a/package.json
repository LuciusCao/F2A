{
  "name": "@f2a/openclaw-f2a",
  "version": "0.4.3",
  "description": "OpenClaw plugin for F2A P2P Agent network",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@f2a/network": "^0.5.0",
    "eventemitter3": "^5.0.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "openclaw",
    "f2a",
    "p2p",
    "agent",
    "plugin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LuciusCao/F2A.git",
    "directory": "packages/openclaw-f2a"
  },
  "license": "MIT",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/plugin.js"
    ]
  }
}
