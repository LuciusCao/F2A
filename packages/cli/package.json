{
  "name": "@f2a/cli",
  "version": "0.9.0",
  "description": "F2A CLI - Command line tools for Friend-to-Agent P2P networking",
  "type": "module",
  "bin": {
    "f2a": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@f2a/network": "*",
    "@f2a/daemon": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "f2a",
    "p2p",
    "agent",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LuciusCao/F2A.git",
    "directory": "packages/cli"
  },
  "license": "MIT"
}
