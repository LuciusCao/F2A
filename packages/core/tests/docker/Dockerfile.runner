# F2A Test Runner Docker Image
# 用于运行集成测试

FROM node:22-alpine

# 安装 better-sqlite3 所需的构建工具
RUN apk add --no-cache python3 make g++

WORKDIR /app

# 复制整个 monorepo
COPY . .

# 在根目录安装所有 workspace 依赖
RUN npm install

# 构建 packages/core
RUN npm run build -w @f2a/network

# 运行集成测试
CMD ["npm", "run", "test:integration"]