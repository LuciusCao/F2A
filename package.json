{
  "name": "@f2a/monorepo",
  "version": "0.4.7",
  "description": "F2A - Friend-to-Agent P2P networking protocol (Monorepo root)",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:core": "npm run build -w @f2a/network",
    "build:adapter": "npm run build -w @f2a/openclaw-adapter",
    "build:dashboard": "npm run build -w @f2a/dashboard",
    "lint": "npm run lint --workspaces",
    "clean": "npm run clean --workspaces && rm -rf node_modules",
    "test": "npm run test -w @f2a/network",
    "test:unit": "npm run test:unit -w @f2a/network",
    "test:coverage": "npm run test:coverage -w @f2a/network",
    "test:integration": "npm run test:integration -w @f2a/network",
    "test:all": "npm run test:all -w @f2a/network",
    "test:ci": "npm run test:ci -w @f2a/network"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "p2p",
    "libp2p",
    "agent",
    "openclaw",
    "networking"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LuciusCao/F2A.git"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}