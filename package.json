{
  "name": "@f2a/monorepo",
  "version": "0.4.8",
  "description": "F2A - Friend-to-Agent P2P networking protocol (Monorepo root)",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:core": "npm run build -w @f2a/network",
    "build:cli": "npm run build -w @f2a/cli",
    "build:daemon": "npm run build -w @f2a/daemon",
    "build:openclaw-f2a": "npm run build -w @f2a/openclaw-f2a",
    "build:dashboard": "npm run build -w @f2a/dashboard",
    "build:all": "npm run build:core && npm run build:cli && npm run build:daemon && npm run build:openclaw-f2a && npm run build:dashboard",
    "lint": "npm run lint --workspaces",
    "clean": "npm run clean --workspaces && rm -rf node_modules",
    "test": "npm run test --workspaces",
    "test:unit": "npm run test:unit --workspaces",
    "test:coverage": "npm run test:coverage --workspaces",
    "test:integration": "npm run test:integration -w @f2a/network",
    "test:docker": "npm run test:docker -w @f2a/network",
    "test:stress": "npm run test:stress -w @f2a/network",
    "test:all": "npm run test:all --workspaces",
    "test:ci": "npm run test:ci --workspaces"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "p2p",
    "libp2p",
    "agent",
    "openclaw",
    "networking"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LuciusCao/F2A.git"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
